# Supabase OAuth (required for Skybridge auth provider)
MCP_USE_OAUTH_SUPABASE_PROJECT_ID=your-supabase-project-id

# Supabase (required for data access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# AI APIs
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Server
PORT=3001
# Set this to your Cloudflare tunnel URL (e.g. https://xxx.trycloudflare.com)
MCP_SERVER_URL=http://localhost:3000
